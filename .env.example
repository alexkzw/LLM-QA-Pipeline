# LLM QA Pipeline - Environment Variable Template
# Copy to .env and fill in your own values. .env is git-ignored.

# Cloudflare API Key (required)
# Get your API key from: https://dash.cloudflare.com/
LLMQA_CLOUDFLARE_API_KEY=

# Cloudflare Account ID (required)
# Find it on any zone/domain's Overview page in the Cloudflare dashboard.
LLMQA_CLOUDFLARE_ACCOUNT_ID=

# Optional: Override model configuration
# LLMQA_MODEL_NAME=@cf/meta/llama-3.1-8b-instruct
# LLMQA_TEMPERATURE=0.7
# LLMQA_MAX_TOKENS=2000

# Optional: Adjust retrieval settings
# LLMQA_CHUNK_SIZE=1000
# LLMQA_CHUNK_OVERLAP=150
# LLMQA_RETRIEVAL_TOP_K=5

# Optional: Logging
# LLMQA_LOG_LEVEL=INFO
# LLMQA_LOG_JSON=false
